{
  "name": "معمل-المستقبل-للتحاليل-الطبية-الكيميائية",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "ts-node server/index.ts",
    "server:dev": "nodemon --watch server --ext ts --exec \"ts-node server/index.ts\"",
    "server:pm2": "pm2 start --name lab-server --interpreter=ts-node server/index.ts --watch",
    "server:pm2-stop": "pm2 stop lab-server || true",
    "server:pm2-save": "pm2 save",
    "start-server": "node server/run.cjs",
    "start-batch": "start run_server.bat",
    "start": "concurrently \"npm run build && npm run server\" || \"npm run server\""
  },
  "dependencies": {
    "@google/genai": "1.41.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.6.1",
    "lucide-react": "0.475.0",
    "mongoose": "^9.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "7.1.0",
    "recharts": "2.15.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "nodemon": "^2.0.22",
    "pm2": "^5.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
